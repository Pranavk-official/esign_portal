# Public API URL (Frontend -> Backend)
# For local dev with proxy, use /api_proxy
# For production, use the full URL (e.g., https://api.esign.ksitm.com)
NEXT_PUBLIC_API_BASE_URL=

# Proxy Target (Used by Next.js Rewrites in next.config.ts)
# Only needed for local development to bypass CORS/Cookie issues
# Defaults to http://10.5.141.53 if not set
API_PROXY_TARGET=