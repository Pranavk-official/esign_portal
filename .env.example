# ──────────────────────────────────────────────────────────────────
#  .env.example — ASP eSign Gateway Frontend
#
#  Copy to .env.local for local development:
#    cp .env.example .env.local
#
#  This file is committed to source control and contains NO secrets.
# ──────────────────────────────────────────────────────────────────

# ── Backend Proxy Target ──────────────────────────────────────────
# URL of the FastAPI backend. Used SERVER-SIDE ONLY by the Next.js
# API proxy route (src/app/api/[...path]/route.ts). Every browser
# request goes through /api/* on this Next.js server, which then
# forwards it to BACKEND_URL — so the real backend IP is never
# exposed to the client bundle.
#
# No NEXT_PUBLIC_ prefix is intentional.
# Falls back to http://localhost:8000 when this variable is unset.
#
# Examples:
#   Local Docker stack : http://localhost:8000
#   Local VM (LAN)     : http://10.5.141.53
#   Dev tunnel (HTTPS) : https://mdrr740x-8000.inc1.devtunnels.ms
BACKEND_URL="http://localhost:8000"

# ── Next.js Server Actions Encryption Key ────────────────────────
# Required in Next.js 15+ to encrypt Server Action payloads.
# Must be a stable 32-byte base64 string — changing it will
# invalidate all in-flight Server Action requests.
#
# Generate with:
#   openssl rand -base64 32
#
# WARNING: Do NOT leave this blank in production. Next.js will
# default to an empty string which breaks action security.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""
